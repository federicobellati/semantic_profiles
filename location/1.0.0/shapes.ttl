<https://w3id.org/cnr-ismar/sap/location/1.0.0/shapes.ttl>
    a owl:Ontology ;
    dcterms:title "CNR ISMAR Location Application Profile - SHACL Shapes"@en ;
    dcterms:description "SHACL shapes for validating RDF descriptions of locations represented as GeoSPARQL Features with associated WKT geometries and research infrastructure membership."@en ;
    dcterms:isPartOf saploc: ;
    owl:versionInfo "1.0.0" ;
    dcterms:conformsTo <https://www.w3.org/TR/shacl/> .
