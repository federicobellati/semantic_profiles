																	
																			   

														   
											   
														   
														  
												
												 
																 
													   
													

														  
					
																			  
																																																 
							  
							 
													   


###############################################################################
# Location shape
###############################################################################

locshape:LocationShape
    a sh:NodeShape ;

    sh:name "Location"@en ;
    sh:description """
A location represented as a GeoSPARQL Feature.

According to this application profile, a location must provide a single
human-readable name expressed both as rdfs:label and dcterms:title for
cross-vocabulary interoperability. The two values must be identical.

The name is expressed as a language-tagged literal using the undetermined
language tag @und.

A location must declare conformance to the INSPIRE Environmental Monitoring
Facilities theme and must have exactly one associated GeoSPARQL Geometry.
		 
"""@en ;

    ###########################################################################
    # Target
    #
    # This shape validates every resource explicitly typed as geo:Feature.
    ###########################################################################

    sh:targetClass geo:Feature ;

    ###########################################################################
    # rdf:type geo:Feature
    ###########################################################################

    sh:property [
        sh:path rdf:type ;
        sh:name "Resource type"@en ;
        sh:description "The resource must be explicitly typed as a GeoSPARQL Feature."@en ;
        sh:order 1 ;
        sh:hasValue geo:Feature ;
        sh:message "A location must be explicitly typed as geo:Feature."@en ;
    ] ;

    ###########################################################################
    # rdfs:label
    #
    # Required.
    # Exactly one value.
    # Must be a language-tagged string using @und.
    # Must be identical to dcterms:title.
    ###########################################################################

    sh:property [
        sh:path rdfs:label ;
        sh:name "Name"@en ;
        sh:description "The human-readable name of the location. The value must be identical to dcterms:title and must use the @und language tag."@en ;
        sh:order 2 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "und" ) ;
        sh:equals dcterms:title ;
        sh:message "A location must have exactly one rdfs:label using the @und language tag, and it must be identical to dcterms:title."@en ;
    ] ;

    ###########################################################################
    # dcterms:title
    #
    # Required.
    # Exactly one value.
    # Must be a language-tagged string using @und.
    #
    # Equality with rdfs:label is enforced by the rdfs:label property shape
    # through sh:equals dcterms:title.
    ###########################################################################

    sh:property [
        sh:path dcterms:title ;
        sh:name "Title"@en ;
        sh:description "The title of the location, provided for cross-vocabulary interoperability. It must be identical to rdfs:label and must use the @und language tag."@en ;
        sh:order 3 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "und" ) ;
        sh:message "A location must have exactly one dcterms:title using the @und language tag, and it must be identical to rdfs:label."@en ;
    ] ;

    ###########################################################################
    # skos:altLabel
    #
    # Optional.
    # Maximum one value.
    # Must be a language-tagged string using @und.
    ###########################################################################

    sh:property [
        sh:path skos:altLabel ;
        sh:name "Alternative name"@en ;
        sh:description "An optional alternative name for the location. At most one alternative label is allowed and it must use the @und language tag."@en ;
        sh:order 4 ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "und" ) ;
        sh:message "skos:altLabel, when present, must be a single language-tagged literal using the @und language tag."@en ;
    ] ;

    ###########################################################################
    # dcterms:description
    #
    # Required.
    # Must be a language-tagged string.
    # Allows one value per language.
    ###########################################################################

    sh:property [
        sh:path dcterms:description ;
        sh:name "Description"@en ;
        sh:description "A textual description of the location. The description must be provided as a language-tagged literal. Only one description per language is allowed."@en ;
        sh:order 5 ;
        sh:minCount 1 ;
        sh:datatype rdf:langString ;
        sh:uniqueLang true ;
        sh:message "A location must have at least one dcterms:description with a language tag. Only one dcterms:description per language is allowed."@en ;
    ] ;

    ###########################################################################
    # dcterms:conformsTo
    #
							   
	 
    # Required.
    # Exactly one value.
    # Must point to the INSPIRE Environmental Monitoring Facilities theme.
																	   
	 
							   
	 
							
    ###########################################################################

    sh:property [
        sh:path dcterms:conformsTo ;
        sh:name "INSPIRE conformance"@en ;
        sh:description "The location must declare conformance to the INSPIRE Environmental Monitoring Facilities theme."@en ;
        sh:order 6 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue <http://inspire.ec.europa.eu/theme/ef> ;
        sh:message "A location must declare dcterms:conformsTo <http://inspire.ec.europa.eu/theme/ef>."@en ;
    ] ;

    ###########################################################################
    # dcterms:isPartOf
    #
			   
	 
																		
							   
	 
    # Optional.
    # May point to a research infrastructure or other aggregating resource.
    # The referenced resource is not validated by this Location profile.
    ###########################################################################

    sh:property [
        sh:path dcterms:isPartOf ;
        sh:name "Part of"@en ;
        sh:description "An optional reference to a research infrastructure or another aggregating resource of which the location is part. The value must be an IRI. The referenced resource is not validated by this Location profile."@en ;
        sh:order 7 ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
													  
        sh:message "dcterms:isPartOf, when present, must be an IRI."@en ;
    ] ;

    ###########################################################################
    # foaf:depiction
    #
    # Optional.
    # If present, it must be an IRI.
    ###########################################################################

    sh:property [
        sh:path foaf:depiction ;
        sh:name "Depiction"@en ;
        sh:description "An optional image or visual depiction of the location. The value must be an IRI."@en ;
        sh:order 8 ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
        sh:message "foaf:depiction, when present, must be an IRI."@en ;
    ] ;

    ###########################################################################
    # geo:hasMetricSpatialAccuracy
    #
    # Optional.
    # Maximum one value.
    # Must be a non-negative numeric value.
    # Accepted datatypes:
    # - xsd:integer
    # - xsd:decimal
    # - xsd:double
    ###########################################################################

    sh:property [
        sh:path geo:hasMetricSpatialAccuracy ;
        sh:name "Metric spatial accuracy"@en ;
        sh:description "The spatial accuracy of the geometry, expressed in meters as a non-negative numeric value. Accepted datatypes are xsd:integer, xsd:decimal and xsd:double."@en ;
        sh:order 9 ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:integer ]
            [ sh:datatype xsd:decimal ]
            [ sh:datatype xsd:double ]
        ) ;
        sh:minInclusive 0 ;
        sh:message "Metric spatial accuracy, when present, must be a single non-negative numeric value using xsd:integer, xsd:decimal or xsd:double."@en ;
    ] ;

    ###########################################################################
    # geo:hasGeometry
    #
    # Required.
    # Exactly one geometry.
    # The geometry must be identified by an IRI.
    # The geometry must be explicitly typed as geo:Geometry.
    # The geometry node must conform to locshape:GeometryShape.
    ###########################################################################

    sh:property [
        sh:path geo:hasGeometry ;
        sh:name "Geometry"@en ;
        sh:description "The single GeoSPARQL geometry associated with the location. The geometry must be an IRI, must be typed as geo:Geometry, and must conform to GeometryShape."@en ;
        sh:order 10 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class geo:Geometry ;
        sh:node locshape:GeometryShape ;
        sh:message "A location must have exactly one geo:hasGeometry value. The geometry must be an IRI, must be typed as geo:Geometry, and must conform to GeometryShape."@en ;
    ] .
