@prefix saploc:   <https://w3id.org/cnr-ismar/sap/location/1.0.0/> .
@prefix locshape: <https://w3id.org/cnr-ismar/sap/location/1.0.0/shapes.ttl#> .

@prefix geo:      <http://www.opengis.net/ont/geosparql#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf:     <http://xmlns.com/foaf/0.1/> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .

<https://w3id.org/cnr-ismar/sap/location/1.0.0/shapes.ttl>
    a owl:Ontology ;
    dcterms:title "CNR ISMAR Location Application Profile - SHACL Shapes"@en ;
    dcterms:description "SHACL shapes for validating RDF descriptions of locations represented as GeoSPARQL Features with associated WKT geometries and research infrastructure membership."@en ;
    dcterms:isPartOf saploc: ;
    owl:versionInfo "1.0.0" ;
    dcterms:conformsTo <https://www.w3.org/TR/shacl/> .																	

###############################################################################
# Location shape
###############################################################################

locshape:LocationShape
    a sh:NodeShape ;

    sh:name "Location"@en ;
    sh:description """
A location represented as a GeoSPARQL Feature.

According to this application profile, a location must provide a single
human-readable name expressed both as rdfs:label and dcterms:title for
cross-vocabulary interoperability. The two values must be identical.

The name is expressed as a language-tagged literal using the English
language tag @en.

A location must declare conformance to the INSPIRE Environmental Monitoring
Facilities theme and must have exactly one associated GeoSPARQL Geometry.

The geometry is expected to be encoded as a three-dimensional WKT geometry
using EPSG:4979, where coordinates are expressed as longitude, latitude and
ellipsoidal height. Longitude and latitude are expressed in decimal degrees
and elevation is expressed in metres.

"""@en ;

    ###########################################################################
    # Target
    ###########################################################################

    sh:targetClass geo:Feature ;

    ###########################################################################
    # rdf:type geo:Feature
    ###########################################################################

    sh:property [
        sh:path rdf:type ;
        sh:name "Resource type"@en ;
        sh:description "The resource must be explicitly typed as a GeoSPARQL Feature."@en ;
        sh:order 1 ;
        sh:hasValue geo:Feature ;
        sh:message "A location must be explicitly typed as geo:Feature."@en ;
    ] ;

    ###########################################################################
    # rdfs:label
    ###########################################################################

    sh:property [
        sh:path rdfs:label ;
        sh:name "Name"@en ;
        sh:description "Human-readable name of the location. The value must be identical to dcterms:title and must use the English language tag."@en ;
        sh:order 2 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "en" ) ;
        sh:equals dcterms:title ;
        sh:message "A location must have exactly one rdfs:label using @en and identical to dcterms:title."@en ;
    ] ;

    ###########################################################################
    # dcterms:title
    ###########################################################################

    sh:property [
        sh:path dcterms:title ;
        sh:name "Title"@en ;
        sh:description "The title of the location. The value must be identical to rdfs:label and must use the English language tag."@en ;
        sh:order 3 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "en" ) ;
        sh:message "A location must have exactly one dcterms:title using @en and identical to rdfs:label."@en ;
    ] ;

    ###########################################################################
    # skos:altLabel
    ###########################################################################

    sh:property [
        sh:path skos:altLabel ;
        sh:name "Alternative name"@en ;
        sh:description "An optional alternative name for the location. At most one alternative label is allowed and it must use the @und language tag."@en ;
        sh:order 4 ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "und" ) ;
        sh:message "skos:altLabel, when present, must be a single language-tagged literal using the @und language tag."@en ;
    ] ;

    ###########################################################################
    # dcterms:description
    ###########################################################################

    sh:property [
        sh:path dcterms:description ;
        sh:name "Description"@en ;
        sh:description "A textual description of the location. The description must be provided as a language-tagged literal. Only one description per language is allowed."@en ;
        sh:order 5 ;
        sh:minCount 1 ;
        sh:datatype rdf:langString ;
        sh:uniqueLang true ;
        sh:message "A location must have at least one dcterms:description with a language tag. Only one dcterms:description per language is allowed."@en ;
    ] ;

    ###########################################################################
    # dcterms:conformsTo
    ###########################################################################

    sh:property [
        sh:path dcterms:conformsTo ;
        sh:name "INSPIRE conformance"@en ;
        sh:description "The location must declare conformance to the INSPIRE Environmental Monitoring Facilities theme."@en ;
        sh:order 6 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue <http://inspire.ec.europa.eu/theme/ef> ;
        sh:message "A location must declare dcterms:conformsTo <http://inspire.ec.europa.eu/theme/ef>."@en ;
    ] ;

    ###########################################################################
    # dcterms:isPartOf
    ###########################################################################

    sh:property [
        sh:path dcterms:isPartOf ;
        sh:name "Part of"@en ;
        sh:description "Optional reference to a research infrastructure. The value must be an IRI and should terminate with a valid local identifier."@en ;
        sh:order 7 ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
        sh:pattern ".*/research-infrastructure/[A-Za-z0-9][A-Za-z0-9_-]*$" ;
        sh:message "Research infrastructure IRIs must end with a valid local identifier."@en ;
    ] ;

    ###########################################################################
    # foaf:depiction
    ###########################################################################

    sh:property [
        sh:path foaf:depiction ;
        sh:name "Depiction"@en ;
        sh:description "Optional visual depiction of the location. The value must be an HTTP or HTTPS IRI."@en ;
        sh:order 8 ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:pattern "^https?://.*$" ;
        sh:message "foaf:depiction must be an HTTP or HTTPS IRI."@en ;
    ] ;

    ###########################################################################
    # geo:hasMetricSpatialAccuracy
    ###########################################################################

    sh:property [
        sh:path geo:hasMetricSpatialAccuracy ;
        sh:name "Metric spatial accuracy"@en ;
        sh:description "Mandatory metric spatial accuracy expressed in metres as a non-negative numeric value."@en ;
        sh:order 9 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:integer ]
            [ sh:datatype xsd:decimal ]
            [ sh:datatype xsd:double ]
        ) ;
        sh:minInclusive 0 ;
        sh:message "Metric spatial accuracy is mandatory and must be a non-negative numeric value."@en ;
    ] ;

    ###########################################################################
    # geo:hasGeometry
    ###########################################################################

    sh:property [
        sh:path geo:hasGeometry ;
        sh:name "Geometry"@en ;
        sh:description "The single GeoSPARQL geometry associated with the location. The geometry must be an IRI, must be typed as geo:Geometry and must conform to GeometryShape."@en ;
        sh:order 10 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class geo:Geometry ;
        sh:node locshape:GeometryShape ;
        sh:message "A location must have exactly one geo:hasGeometry value. The geometry must be an IRI, must be typed as geo:Geometry and must conform to GeometryShape."@en ;
    ] .


###############################################################################
# Geometry shape
###############################################################################

locshape:GeometryShape
    a sh:NodeShape ;

    sh:name "Geometry"@en ;
    sh:description """
A GeoSPARQL geometry encoded as a three-dimensional WKT literal.

The geometry shall use CRS EPSG:4979 and shall be encoded as:

POINT Z(longitude latitude elevation)

Longitude and latitude are expressed in decimal degrees.
Elevation is expressed as WGS84 ellipsoidal height in metres and
may be positive or negative.
"""@en ;

    ###########################################################################
    # rdf:type
    ###########################################################################

    sh:property [
        sh:path rdf:type ;
        sh:hasValue geo:Geometry ;
        sh:name "Geometry type"@en ;
        sh:message "The geometry must be explicitly typed as geo:Geometry."@en ;
    ] ;

    ###########################################################################
    # geo:asWKT
    ###########################################################################

    sh:property [
        sh:path geo:asWKT ;
        sh:name "WKT geometry"@en ;
        sh:description "Three-dimensional WKT literal encoded using EPSG:4979."@en ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype geo:wktLiteral ;

        sh:pattern "^<http://www\\.opengis\\.net/def/crs/EPSG/0/4979>\\s+POINT\\s+Z\\s*\\([-+]?[0-9]+(\\.[0-9]+)?\\s+[-+]?[0-9]+(\\.[0-9]+)?\\s+[-+]?[0-9]+(\\.[0-9]+)?\\s*\\)$" ;

        sh:message "The WKT geometry must use EPSG:4979 and be encoded as POINT Z(longitude latitude elevation)."@en ;
    ] .
