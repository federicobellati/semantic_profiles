@prefix saploc:   <https://w3id.org/cnr-ismar/sap/location/1.0.0/> .
@prefix locshape: <https://w3id.org/cnr-ismar/sap/location/1.0.0/shapes.ttl#> .

@prefix geo:      <http://www.opengis.net/ont/geosparql#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf:     <http://xmlns.com/foaf/0.1/> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .

<https://w3id.org/cnr-ismar/sap/location/1.0.0/shapes.ttl>
    a owl:Ontology ;
    dcterms:title "CNR ISMAR Location Application Profile - SHACL Shapes"@en ;
    dcterms:description """
SHACL shapes for validating RDF descriptions of locations represented as
GeoSPARQL Features with associated WKT geometries and optional links to
research infrastructures.

This profile reflects the constraints implemented by the reference Turtle
Generator for GeoSPARQL Locations. Location resources are expected to be
identified by IRIs under:

https://w3id.org/cnr-ismar/resource/location/{ID}

where {ID} is a local identifier composed of letters, numbers, hyphens or
underscores, starting with a letter or number.
"""@en ;
    dcterms:isPartOf saploc: ;
    owl:versionInfo "1.0.0" ;
    dcterms:conformsTo <https://www.w3.org/TR/shacl/> .


###############################################################################
# Location shape
###############################################################################

locshape:LocationShape
    a sh:NodeShape ;

    sh:name "Location"@en ;
    sh:description """
A location represented as a GeoSPARQL Feature.

According to this application profile, a Location resource must be identified
by an IRI following this pattern:

https://w3id.org/cnr-ismar/resource/location/{ID}

The local identifier {ID} must start with a letter or number and may contain
letters, numbers, hyphens or underscores.

A location must provide a single human-readable name expressed both as
rdfs:label and dcterms:title for cross-vocabulary interoperability. The two
values must be identical, must use the English language tag @en, and must be
at least three characters long.

A location must provide exactly one English textual description using
dcterms:description with language tag @en.

An alternative label must be generated from the local identifier according to
the reference form convention:

{ID} for future uses

and must be provided as skos:altLabel using the undefined language tag @und.

A location must declare conformance to the INSPIRE Environmental Monitoring
Facilities theme and must have exactly one associated GeoSPARQL Geometry.

The geometry is expected to be encoded as a three-dimensional WKT geometry
using EPSG:4979, where coordinates are expressed as longitude, latitude and
ellipsoidal height. Longitude and latitude are expressed in decimal degrees
and elevation is expressed in metres.
"""@en ;

    ###########################################################################
    # Target
    ###########################################################################

    sh:targetClass geo:Feature ;

    ###########################################################################
    # Location IRI
    ###########################################################################

    sh:nodeKind sh:IRI ;
    sh:pattern "^https://w3id\\.org/cnr-ismar/resource/location/[A-Za-z0-9][A-Za-z0-9_-]*$" ;
    sh:message "The Location IRI must follow the pattern https://w3id.org/cnr-ismar/resource/location/{ID}, where ID starts with a letter or number and contains only letters, numbers, hyphens or underscores."@en ;

    ###########################################################################
    # rdf:type geo:Feature
    ###########################################################################

    sh:property [
        sh:path rdf:type ;
        sh:name "Resource type"@en ;
        sh:description "The resource must be explicitly typed as a GeoSPARQL Feature."@en ;
        sh:order 1 ;
        sh:hasValue geo:Feature ;
        sh:message "A location must be explicitly typed as geo:Feature."@en ;
    ] ;

    ###########################################################################
    # rdfs:label
    ###########################################################################

    sh:property [
        sh:path rdfs:label ;
        sh:name "Name"@en ;
        sh:description "Human-readable feature name. It is emitted by the reference form as rdfs:label with language tag @en. The value must be identical to dcterms:title and must contain at least three characters."@en ;
        sh:order 2 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "en" ) ;
        sh:minLength 3 ;
        sh:equals dcterms:title ;
        sh:message "A location must have exactly one rdfs:label using @en, at least three characters long, and identical to dcterms:title."@en ;
    ] ;

    ###########################################################################
    # dcterms:title
    ###########################################################################

    sh:property [
        sh:path dcterms:title ;
        sh:name "Title"@en ;
        sh:description "Human-readable feature title. It is emitted by the reference form as dcterms:title with language tag @en. The value must be identical to rdfs:label and must contain at least three characters."@en ;
        sh:order 3 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "en" ) ;
        sh:minLength 3 ;
        sh:equals rdfs:label ;
        sh:message "A location must have exactly one dcterms:title using @en, at least three characters long, and identical to rdfs:label."@en ;
    ] ;

    ###########################################################################
    # skos:altLabel
    ###########################################################################

    sh:property [
        sh:path skos:altLabel ;
        sh:name "Alternative name"@en ;
        sh:description "Alternative label generated by the reference form from the local identifier. The generated value follows the convention '{ID} for future uses'. It must be provided as a single language-tagged literal using the @und language tag."@en ;
        sh:order 4 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "und" ) ;
        sh:minLength 3 ;
        sh:pattern "^[A-Za-z0-9][A-Za-z0-9_-]* for future uses$" ;
        sh:message "A location must have exactly one skos:altLabel using @und and following the pattern '{ID} for future uses'."@en ;
    ] ;

    ###########################################################################
    # dcterms:description
    ###########################################################################

    sh:property [
        sh:path dcterms:description ;
        sh:name "Description"@en ;
        sh:description "Textual description of the location. It is emitted by the reference form as dcterms:description with language tag @en and must contain at least three characters."@en ;
        sh:order 5 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "en" ) ;
        sh:minLength 3 ;
        sh:message "A location must have exactly one dcterms:description using @en and containing at least three characters."@en ;
    ] ;

    ###########################################################################
    # dcterms:conformsTo
    ###########################################################################

    sh:property [
        sh:path dcterms:conformsTo ;
        sh:name "INSPIRE conformance"@en ;
        sh:description "The location must declare conformance to the INSPIRE Environmental Monitoring Facilities theme."@en ;
        sh:order 6 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue <http://inspire.ec.europa.eu/theme/ef> ;
        sh:message "A location must declare dcterms:conformsTo <http://inspire.ec.europa.eu/theme/ef>."@en ;
    ] ;

    ###########################################################################
    # dcterms:isPartOf
    ###########################################################################

    sh:property [
        sh:path dcterms:isPartOf ;
        sh:name "Part of"@en ;
        sh:description "Optional reference to a research infrastructure. The value must be an IRI. The reference form accepts local research infrastructure identifiers and emits them as IRIs, but this profile intentionally allows external infrastructure IRIs because the final URI pattern is not yet fixed."@en ;
        sh:order 7 ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
        sh:message "Research infrastructure references, when present, must be IRIs."@en ;
    ] ;

    ###########################################################################
    # foaf:depiction
    ###########################################################################

    sh:property [
        sh:path foaf:depiction ;
        sh:name "Depiction"@en ;
        sh:description "Optional external visual depiction of the location. If provided, the value must be an absolute HTTP or HTTPS IRI."@en ;
        sh:order 8 ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:pattern "^https?://[^\\s<>\"']+$" ;
        sh:flags "i" ;
        sh:message "foaf:depiction must be an absolute HTTP or HTTPS IRI without spaces, angle brackets or quotes."@en ;
    ] ;

    ###########################################################################
    # geo:hasMetricSpatialAccuracy
    ###########################################################################

    sh:property [
        sh:path geo:hasMetricSpatialAccuracy ;
        sh:name "Metric spatial accuracy"@en ;
        sh:description "Mandatory metric spatial accuracy expressed in metres as a non-negative numeric value. The reference form emits this value as xsd:double."@en ;
        sh:order 9 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:integer ]
            [ sh:datatype xsd:decimal ]
            [ sh:datatype xsd:double ]
        ) ;
        sh:minInclusive 0 ;
        sh:message "Metric spatial accuracy is mandatory and must be a non-negative numeric value expressed in metres."@en ;
    ] ;

    ###########################################################################
    # geo:hasGeometry
    ###########################################################################

    sh:property [
        sh:path geo:hasGeometry ;
        sh:name "Geometry"@en ;
        sh:description "The single GeoSPARQL geometry associated with the location. The geometry must be an IRI, must be explicitly typed as geo:Geometry, and must conform to GeometryShape."@en ;
        sh:order 10 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class geo:Geometry ;
        sh:node locshape:GeometryShape ;
        sh:message "A location must have exactly one geo:hasGeometry value. The geometry must be an IRI, must be typed as geo:Geometry and must conform to GeometryShape."@en ;
    ] .


###############################################################################
# Geometry shape
###############################################################################

locshape:GeometryShape
    a sh:NodeShape ;

    sh:name "Geometry"@en ;
    sh:description """
A GeoSPARQL geometry encoded as a three-dimensional WKT literal.

The geometry must use CRS EPSG:4979 and must be encoded as:

POINT Z(longitude latitude elevation)

Longitude is the east coordinate and is written before latitude.
Longitude and latitude are expressed in decimal degrees.
Elevation is expressed as WGS84 ellipsoidal height in metres and may be
positive or negative.

The reference form generates the geometry as a geo:wktLiteral using:

<http://www.opengis.net/def/crs/EPSG/0/4979> POINT Z(lon lat elevation)
"""@en ;

    ###########################################################################
    # rdf:type geo:Geometry
    ###########################################################################

    sh:property [
        sh:path rdf:type ;
        sh:hasValue geo:Geometry ;
        sh:name "Geometry type"@en ;
        sh:description "The geometry resource must be explicitly typed as geo:Geometry."@en ;
        sh:message "The geometry must be explicitly typed as geo:Geometry."@en ;
    ] ;

    ###########################################################################
    # geo:asWKT
    ###########################################################################

    sh:property [
        sh:path geo:asWKT ;
        sh:name "WKT geometry"@en ;
        sh:description "Three-dimensional WKT literal encoded using EPSG:4979. The WKT must be written as POINT Z(longitude latitude elevation), where longitude and latitude are decimal degrees and elevation is WGS84 ellipsoidal height in metres."@en ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype geo:wktLiteral ;
        sh:pattern "^<http://www\\.opengis\\.net/def/crs/EPSG/0/4979>\\s+POINT\\s+Z\\s*\\([-+]?[0-9]+(\\.[0-9]+)?\\s+[-+]?[0-9]+(\\.[0-9]+)?\\s+[-+]?[0-9]+(\\.[0-9]+)?\\s*\\)$" ;
        sh:message "The WKT geometry must use EPSG:4979 and be encoded as POINT Z(longitude latitude elevation)."@en ;
    ] .
